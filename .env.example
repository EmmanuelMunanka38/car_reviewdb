# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-or-anon-key
# Prefer using the service role key on the server for admin actions and storage uploads
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=review-images
# Postgres connection string for Prisma (use your Supabase DB connection)
# Example: postgresql://postgres:password@db.abc123.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security / CORS
# Comma-separated list of allowed origins for CORS (e.g., https://example.com,http://localhost:3000)
ALLOWED_ORIGINS=http://localhost:3000

# Server
PORT=4000

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Supabase JWT Secret (from Supabase Dashboard → Settings → API → JWT Secret)
# Used to verify admin auth tokens server-side
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Logging
LOG_LEVEL=info
