generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  draft
  published
}

model Profile {
  id         String    @id @default(uuid()) @db.Uuid
  full_name  String? 
  role       String
  created_at DateTime  @default(now())
  Review     Review[]  @relation("ProfileReviews")

  @@map("profiles")
}

model Review {
  id             String         @id @default(uuid()) @db.Uuid
  slug           String         @unique
  title          String
  excerpt        String?
  featured_image String?
  manufacturer   String
  model          String
  year           Int
  content        Json
  rating         Float?
  status         ReviewStatus   @default(draft)
  published_at   DateTime?
  created_by     String         @db.Uuid
  created_at     DateTime       @default(now())
  updated_at     DateTime?

  profile        Profile        @relation(fields: [created_by], references: [id], name: "ProfileReviews")
  specs          ReviewSpec[]
  gallery        ReviewGallery[]

  @@map("reviews")
}

model ReviewSpec {
  id           String  @id @default(uuid()) @db.Uuid
  review_id    String  @db.Uuid
  engine       String?
  horsepower   Int?
  torque       Int?
  transmission String?
  drivetrain   String?
  fuel_type    String?
  fuel_economy String?
  top_speed    String?
  acceleration String?
  seating      Int?
  price        Float?

  review       Review  @relation(fields: [review_id], references: [id])

  @@map("review_specs")
}

model ReviewGallery {
  id        String  @id @default(uuid()) @db.Uuid
  review_id String  @db.Uuid
  image_url String
  alt_text  String?
  sort_order Int?

  review    Review  @relation(fields: [review_id], references: [id])

  @@map("review_gallery")
}
