generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  draft
  published
}

enum CommentStatus {
  approved
  pending
  spam
}

model Profile {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  password_hash String
  full_name     String?
  role          String    @default("user")
  created_at    DateTime  @default(now())

  Review     Review[]  @relation("ProfileReviews")
  Comment    Comment[] @relation("ProfileComments")

  @@map("profiles")
}

model Review {
  id             String         @id @default(uuid()) @db.Uuid
  slug           String         @unique
  title          String
  excerpt        String?
  featured_image String?
  manufacturer   String
  model          String
  year           Int
  content        Json
  rating         Float?
  status         ReviewStatus   @default(draft)
  featured       Boolean        @default(false)
  views          Int            @default(0)
  published_at   DateTime?
  created_by     String         @db.Uuid
  created_at     DateTime       @default(now())
  updated_at     DateTime?
  deleted_at     DateTime?

  profile        Profile        @relation(fields: [created_by], references: [id], name: "ProfileReviews")
  specs          ReviewSpec[]
  gallery        ReviewGallery[]
  comments       Comment[]

  @@map("reviews")
}

model ReviewSpec {
  id           String  @id @default(uuid()) @db.Uuid
  review_id    String  @db.Uuid
  engine       String?
  horsepower   Int?
  torque       Int?
  transmission String?
  drivetrain   String?
  fuel_type    String?
  fuel_economy String?
  top_speed    String?
  acceleration String?
  seating      Int?
  price        Float?

  review       Review  @relation(fields: [review_id], references: [id])

  @@map("review_specs")
}

model ReviewGallery {
  id        String  @id @default(uuid()) @db.Uuid
  review_id String  @db.Uuid
  image_url String
  alt_text  String?
  sort_order Int?

  review    Review  @relation(fields: [review_id], references: [id])

  @@map("review_gallery")
}

model Comment {
  id           String        @id @default(uuid()) @db.Uuid
  review_id    String        @db.Uuid
  author_name  String
  author_email String?
  body         String
  status       CommentStatus @default(pending)
  created_by   String?       @db.Uuid
  created_at   DateTime      @default(now())

  review       Review        @relation(fields: [review_id], references: [id])
  profile      Profile?      @relation(fields: [created_by], references: [id], name: "ProfileComments")

  @@map("comments")
}
